# ====================================
# ChefPro - Variables de entorno
# ====================================
# Copia este fichero como .env y rellena los valores.
#   cp .env.example .env
#
# IMPORTANTE: NO subas el fichero .env a Git.

# --- MySQL ---
MYSQL_ROOT_PASSWORD=cambia_esta_contrasena
MYSQL_DATABASE=chef_pro

# --- Spring Boot (Backend) ---
SPRING_DATASOURCE_URL=jdbc:mysql://db:3306/chef_pro
SPRING_DATASOURCE_USERNAME=root
SPRING_DATASOURCE_PASSWORD=cambia_esta_contrasena

# --- JWT (genera uno seguro con: openssl rand -hex 32) ---
JWT_SECRET=genera_un_secret_aleatorio_de_64_caracteres_minimo

# --- CORS (separa múltiples orígenes con coma) ---
# Desarrollo: http://localhost:4200
# Producción: https://tu-dominio.com
CORS_ALLOWED_ORIGINS=http://localhost:4200

# --- Logging SQL (usar WARN o ERROR en producción) ---
SPRING_JPA_SHOW_SQL=false
LOG_LEVEL_SQL=WARN
LOG_LEVEL_BIND=WARN
